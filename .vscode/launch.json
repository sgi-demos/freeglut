    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug demo MAC",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/${relativeFileDirname}/bin/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/${relativeFileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb"
        },
        {
            "name": "Debug demo WIN",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/${relativeFileDirname}/bin/${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/${relativeFileDirname}",
            "environment": [
                    { "name": "PATH", "value": "C:\\msys64\\clang64\\bin;${env:PATH}" }
                ],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/clang64/bin/gdb.exe"
        }
    ]
}
